{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/blocks/**",
              "components/brand/**",
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "ui_kits/website/**",
              "webflow-export/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Interstate))/i]",
        "message": "Font not provided by the design system. Available: Interstate."
      },
      {
        "selector": "JSXOpeningElement[name.name='AudienceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|description|tone|href|key|ref|className|style|children)$/]",
        "message": "<AudienceCard> doesn't accept that prop. Declared props: title, description, tone, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='AudienceCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:red|black|gold|white)$/]",
        "message": "<AudienceCard> tone must be one of 'red' | 'black' | 'gold' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|as|href|disabled|iconBefore|iconAfter|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, as, href, disabled, iconBefore, iconAfter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|dark|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'dark' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|number|pad|minHeight|align|justify|key|ref|className|style|children)$/]",
        "message": "<ColorBlock> doesn't accept that prop. Declared props: tone, children, number, pad, minHeight, align, justify."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColorBlock'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:red|black|gold|white|redTint|goldTint|gray)$/]",
        "message": "<ColorBlock> tone must be one of 'red' | 'black' | 'gold' | 'white' | 'redTint' | 'goldTint' | 'gray'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|hint|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, id, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='JourneyBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:active|basePath|onSelect|key|ref|className|style|children)$/]",
        "message": "<JourneyBar> doesn't accept that prop. Declared props: active, basePath, onSelect."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|tone|height|basePath|alt|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, tone, height, basePath, alt."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:full|mark)$/]",
        "message": "<Logo> variant must be one of 'full' | 'mark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:color|white)$/]",
        "message": "<Logo> tone must be one of 'color' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgramCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|fullName|line|tags|image|href|key|ref|className|style|children)$/]",
        "message": "<ProgramCard> doesn't accept that prop. Declared props: label, fullName, line, tags, image, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchField'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|compact|key|ref|className|style|children)$/]",
        "message": "<SearchField> doesn't accept that prop. Declared props: placeholder, compact."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageGlyph'] > JSXAttribute > JSXIdentifier[name!=/^(?:stage|variant|size|basePath|key|ref|className|style|children)$/]",
        "message": "<StageGlyph> doesn't accept that prop. Declared props: stage, variant, size, basePath."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageGlyph'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:transparent|tiled)$/]",
        "message": "<StageGlyph> variant must be one of 'transparent' | 'tiled'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|tone|align|key|ref|className|style|children)$/]",
        "message": "<StatBlock> doesn't accept that prop. Declared props: value, label, tone, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|red|dark|gold)$/]",
        "message": "<StatBlock> tone must be one of 'light' | 'red' | 'dark' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatBlock> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|interactive|pressed|tone|onClick|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, interactive, pressed, tone, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|red|gold|dark)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'red' | 'gold' | 'dark'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
